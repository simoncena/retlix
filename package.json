{
  "name": "retlix",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Autonomous Netflix-style IPTV app powered by Xtream Codes",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon --quiet --watch server --ext js server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "setup": "npm install && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "hls.js": "^1.5.17",
    "mpegts.js": "^1.7.3",
    "nodemon": "^3.1.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "vite": "^5.4.11"
  }
}
